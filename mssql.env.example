# Copy this file to mssql.env and replace the placeholder values.
# mssql.env is ignored by git and must not be committed.

MSSQL_HOST=localhost
MSSQL_DB=ReportForge
MSSQL_USER=your_sql_user
MSSQL_PASSWORD=your_sql_password
MSSQL_ENCRYPT=yes
MSSQL_TRUST_CERT=yes

# Base64-encoded 32-byte key used to encrypt source passwords.
# Example PowerShell generator:
# [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
SECRET_KEY=replace_with_base64_32_byte_key
